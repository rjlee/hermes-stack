# CamoFox Browser environment variables
# Copy this file to .env if you need to override defaults

# =============================================================================
# OPTIONAL - defaults work for most use cases
# =============================================================================

# Port for the CamoFox server (default: 9377)
# CAMOFOX_PORT=9377

# Headless mode: "virtual", "true", "false"
# CAMOFOX_HEADLESS=virtual

# VNC timeout in milliseconds (default: 300000)
# CAMOFOX_VNC_TIMEOUT_MS=300000

# API key for remote access (uncomment to enable auth)
# CAMOFOX_API_KEY=your_api_key_here