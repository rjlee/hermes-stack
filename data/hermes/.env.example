# =============================================================================
# Hermes Agent Environment Configuration
# Copy this file to .env and fill in your API keys
# =============================================================================

# =============================================================================
# REQUIRED
# =============================================================================
API_SERVER_KEY=YOUR_HERMES_API_KEY

# =============================================================================
# LLM PROVIDERS (uncomment and set at least one)
# =============================================================================

# OpenRouter (recommended - access to many models)
# Get your key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# Google AI Studio / Gemini
# Get your key at: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=

# OpenCode Zen (pay-as-you-go)
# Get your key at: https://opencode.ai/auth
# OPENCODE_ZEN_API_KEY=

# OpenCode Go ($10/month for open models)
# Get your key at: https://opencode.ai/auth
# OPENCODE_GO_API_KEY=

# Hugging Face Inference Providers
# Get your token at: https://huggingface.co/settings/tokens
# HF_TOKEN=

# =============================================================================
# TOOL API KEYS (optional)
# =============================================================================

# Exa API Key - AI-native web search
# Get at: https://exa.ai
# EXA_API_KEY=

# Firecrawl API Key - Web crawl and extract
# Get at: https://firecrawl.dev/
# FIRECRAWL_API_KEY=

# Browserbase - Cloud browser execution
# Get at: https://browserbase.com/
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=

# =============================================================================
# TERMINAL TOOL CONFIGURATION
# =============================================================================
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300
TERMINAL_MODAL_IMAGE=nikolaik/python-nodejs:python3.11-nodejs20

# =============================================================================
# BROWSER TOOLS
# =============================================================================
BROWSERBASE_PROXIES=true
BROWSERBASE_ADVANCED_STEALTH=false
BROWSER_SESSION_TIMEOUT=300
BROWSER_INACTIVITY_TIMEOUT=120

# =============================================================================
# MESSAGING INTEGRATIONS (optional)
# =============================================================================

# WhatsApp (run `hermes whatsapp` to pair)
# WHATSAPP_ENABLED=false
# WHATSAPP_ALLOWED_USERS=

# Slack
# SLACK_BOT_TOKEN=
# SLACK_ALLOWED_USERS=

# Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=

# Email (IMAP/SMTP)
# EMAIL_ADDRESS=
# EMAIL_PASSWORD=
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_SMTP_HOST=smtp.gmail.com

# =============================================================================
# GATEWAY CONFIGURATION
# =============================================================================
GATEWAY_ALLOW_ALL_USERS=false

# =============================================================================
# DEBUG OPTIONS
# =============================================================================
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
MOA_TOOLS_DEBUG=false
IMAGE_TOOLS_DEBUG=false