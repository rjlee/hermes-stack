# Open‑WebUI environment variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED - generated by ./hermes-stack setup
# =============================================================================
WEBUI_SECRET_KEY=YOUR_WEBUI_SECRET

# =============================================================================
# OPTIONAL
# =============================================================================

# Allow new users to sign up (default: true)
# ENABLE_SIGNUP=false
# Enables or disables authentication (default: true)
# WEBUI_AUTH=false
