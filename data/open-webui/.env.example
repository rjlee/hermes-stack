# Open‑WebUI environment variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED
# =============================================================================
WEBUI_SECRET_KEY=YOUR_WEBUI_SECRET

# =============================================================================
# OPTIONAL
# =============================================================================

# Allow new users to sign up (default: true)
ENABLE_SIGNUP=true

# Authentication mode: "none", "ldap", etc.
WEBUI_AUTH=none

# OpenAI API key (also defined in data/hermes/.env - only needed here if different)
# OPENAI_API_KEY=YOUR_OPENAI_KEY