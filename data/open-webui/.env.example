# Open‑WebUI environment variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED - generated by ./hermes-stack setup
# =============================================================================
WEBUI_SECRET_KEY=YOUR_WEBUI_SECRET

# =============================================================================
# OPTIONAL
# =============================================================================

# Allow new users to sign up (default: true)
# ENABLE_SIGNUP=true
# Enable password authentication (default: true)
# ENABLE_PASSWORD_AUTH=true
# Enable login form (default: true)
# ENABLE_LOGIN_FORM=true
