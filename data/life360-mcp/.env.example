# Life360 MCP Server environment variables
# Copy this file to .env and fill in your credentials

# =============================================================================
# AUTHENTICATION - Choose ONE method
# =============================================================================

# Method 1: Authorization token (from Life360 app: Settings → Account → Authorization Token)
# LIFE360_AUTHORIZATION=your_token_here
# LIFE360_TOKEN_TYPE=Bearer  # optional, defaults to Bearer

# Method 2: Username & Password (OAuth)
# LIFE360_USERNAME=your_email@example.com
# LIFE360_PASSWORD=your_password
# LIFE360_CLIENT_ID=life360_mobile_app  # optional

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# Cache TTL in seconds (default: 30)
# LIFE360_CACHE_TTL=30

# Max retries for 429/5xx errors (default: 5)
# LIFE360_MAX_RETRIES=5

# Logging level (default: INFO)
# LIFE360_LOG_LEVEL=INFO

# HTTP server port (default: 8123)
# LIFE360_HTTP_PORT=8123