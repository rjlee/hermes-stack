# Root .env - most configuration is in data/*/.env files
# See data/hermes/.env.example, data/open-webui/.env.example, data/camofox-browser/.env.example

WORKSPACE_DIR=./workspace

# Custom Hermes build (true = build custom image with OpenCode, false = pull standard nousresearch/hermes-agent)
CUSTOM_HERMES=false
# HERMES_IMAGE=nosresearch/hermes-agent:latest  # Override image when CUSTOM_HERMES=true