# Root .env - secrets are defined here and used by all services via Docker Compose

WORKSPACE_DIR=./workspace

# =============================================================================
# REQUIRED - Secrets
# =============================================================================
API_SERVER_KEY=93701503ba74e6946aa97376582716eb6b4e3fd9dc4c662557bb1365e06fc0d9

# =============================================================================
# OPTIONAL - Build settings
# =============================================================================
# Custom Hermes build (true = build custom image with OpenCode, false = pull standard nousresearch/hermes-agent)
# CUSTOM_HERMES=false
# Override image when CUSTOM_HERMES=true
# HERMES_IMAGE=nosresearch/hermes-agent:latest

# =============================================================================
# OPTIONAL - Container user mapping (for v0.9+)
# =============================================================================
# Remap container hermes user to match host UID/GID (default: 1000)
# Set to 0 for root deployments
# HERMES_UID=1000
# HERMES_GID=1000
