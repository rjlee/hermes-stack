#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

BASE_IMAGE_NAME="nousresearch/hermes-agent:latest"

# Load environment variables
[[ -f .env ]] && set -a && source .env && set +a

# Determine Hermes image based on CUSTOM_HERMES env var
# CUSTOM_HERMES=false (default) -> use standard nousresearch/hermes-agent
# CUSTOM_HERMES=true -> build custom hermes-stack-hermes
if [[ "${CUSTOM_HERMES:-false}" == "true" ]]; then
    HERMES_IMAGE="${HERMES_IMAGE:-hermes-stack-hermes}"
    export HERMES_IMAGE
else
    HERMES_IMAGE="${HERMES_IMAGE:-nousresearch/hermes-agent:latest}"
    export HERMES_IMAGE
fi

print_help() {
cat <<'EOF'
hermes-stack – helper script for the hermes-stack project

Usage: $0 {up|down|logs|restart|backup|restore|prune|status|check-env|upgrade-base|install|help} [options]

Commands:
  up               Start the stack. Use --upgrade to pull latest images and rebuild Hermes.
  down             Stop and remove containers, networks and default volumes.
  logs             Follow live logs of all services.
  restart          Stop and start containers. Use --upgrade to pull latest and rebuild.
  backup [--retain N] [--dry-run]
                   Create a timestamped backup of data/ and workspace/.
                   The script automatically keeps only the most recent N
                   archives (default 7). Use --dry-run to list files that
                   would be pruned without deleting them.
  restore          Prompt for a backup file and extract it.
  prune            Remove unused Docker images and volumes.
  status           Show container status (health column).
  check-env        Validate required environment variables.
  upgrade-base     Pull the latest base image and display its digests.
  install skills   Install skills from ./skills/ to ./data/hermes/skills/
  cli             Spawn an interactive hermes container (CLI mode)
  setup [life360]  Set up secrets in .env and run hermes setup in container
                  life360 - Configure Life360 MCP authentication
  reset [services] Reset data directories (default: all services)
  help             Show this help message.
EOF
}

# -------------------------------------------------
# Digest helpers
# -------------------------------------------------
get_remote_digest() {
    docker manifest inspect "$BASE_IMAGE_NAME" 2>/dev/null \
        | grep -m1 '"digest"' \
        | awk -F'"' '{print $4}'
}

resolve_base_image() {
    local digest
    digest=$(get_remote_digest)

    if [[ -z "$digest" ]]; then
        echo "❌ Failed to resolve remote digest"
        exit 1
    fi

    echo "${BASE_IMAGE_NAME%@*}@${digest}"
}

needs_rebuild() {
    local remote_digest local_digest

    remote_digest=$(get_remote_digest)

    local_digest=$(docker image inspect hermes-stack-hermes \
        --format '{{ index .Config.Labels "org.opencontainers.image.revision" }}' \
        2>/dev/null || echo "")

    [[ "$remote_digest" != "$local_digest" ]]
}

# -------------------------------------------------
# Build
# -------------------------------------------------
build_image() {
    local base_image base_digest

    base_image=$(resolve_base_image)
    base_digest="${base_image##*@}"

    echo "🔨 Building with base image:"
    echo "   $base_image"

    docker compose --progress=plain build \
        --no-cache \
        --pull \
        --build-arg BASE_IMAGE="$base_image" \
        --build-arg BASE_DIGEST="$base_digest" \
        --build-arg BUILD_TIME="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}

# -------------------------------------------------
# Life360 Setup
# -------------------------------------------------
setup_life360()
{
    echo "📍 Life360 MCP Configuration"
    echo ""
    echo "Choose authentication method:"
    echo "  1) Skip (configure manually later)"
    echo "  2) Authorization token (from Life360 app)"
    echo "  3) Username + Password (OAuth)"
    echo ""
    read -p "Enter choice [1]: " CHOICE
    CHOICE="${CHOICE:-1}"

    ENV_FILE="data/life360-mcp/.env"

    if [[ "$CHOICE" == "1" ]] || [[ "$CHOICE" == "skip" ]]; then
        echo "Skipped. Edit $ENV_FILE manually when ready."
        return 0
    fi

    echo ""

    if [[ "$CHOICE" == "2" ]]; then
        read -p "Authorization token: " LIFE360_AUTHORIZATION
        if [[ -n "$LIFE360_AUTHORIZATION" ]]; then
            echo "LIFE360_AUTHORIZATION=$LIFE360_AUTHORIZATION" > "$ENV_FILE"
            echo "LIFE360_TOKEN_TYPE=Bearer" >> "$ENV_FILE"
            echo "  ✅ Saved authorization token"
        fi
    elif [[ "$CHOICE" == "3" ]]; then
        read -p "Username (email): " LIFE360_USERNAME
        read -s -p "Password: " LIFE360_PASSWORD
        echo ""
        if [[ -n "$LIFE360_USERNAME" ]] && [[ -n "$LIFE360_PASSWORD" ]]; then
            echo "LIFE360_USERNAME=$LIFE360_USERNAME" > "$ENV_FILE"
            echo "LIFE360_PASSWORD=$LIFE360_PASSWORD" >> "$ENV_FILE"
            echo "LIFE360_CLIENT_ID=life360_mobile_app" >> "$ENV_FILE"
            echo "  ✅ Saved username/password"
        fi
    else
        echo "Invalid choice: $CHOICE"
        return 1
    fi

    echo ""
    read -p "Restart hermes-stack now? [y/N]: " RESTART
    if [[ "$RESTART" == "y" ]] || [[ "$RESTART" == "Y" ]]; then
        echo ""
        echo "Restarting hermes-stack..."
        docker compose restart hermes life360-mcp
    fi
}

# -------------------------------------------------
# Commands
# -------------------------------------------------
case "${1:-}" in

up)
    UPGRADE=0
    shift || true
    for arg in "$@"; do
        [[ "$arg" == "--upgrade" ]] && UPGRADE=1
    done

    if [[ "${CUSTOM_HERMES:-false}" == "true" ]]; then
        if [[ $UPGRADE -eq 1 ]]; then
            echo "⬆️ Upgrading custom Hermes - pulling and rebuilding"
            # Pull other images but skip hermes (we'll build it)
            docker compose pull --ignore-buildable hermes
            build_image
        else
            echo "✅ Custom Hermes build ready – use --upgrade to rebuild"
        fi
    else
        docker compose pull
    fi

    docker compose up -d
    ;;

restart)
    UPGRADE=0
    shift || true
    for arg in "$@"; do
        [[ "$arg" == "--upgrade" ]] && UPGRADE=1
    done

    docker compose down

    if [[ "${CUSTOM_HERMES:-false}" == "true" ]]; then
        if [[ $UPGRADE -eq 1 ]]; then
            echo "⬆️ Upgrading custom Hermes - pulling and rebuilding"
            docker compose pull --ignore-buildable hermes
            build_image
        else
            echo "✅ Custom Hermes build ready – use --upgrade to rebuild"
        fi
    else
        docker compose pull
    fi

    docker compose up -d
    ;;

down)
    docker compose down
    ;;

logs)
    docker compose logs -f
    ;;

cli)
    if [[ "${2:-}" == "help" ]] || [[ "${2:-}" == "-h" ]]; then
        echo "Usage: $0 cli"
        echo "  Spawn an interactive hermes container (CLI mode)."
        exit 0
    fi

    if [[ -t 0 ]]; then
        DOCKER_FLAGS="-it"
    else
        DOCKER_FLAGS="-i"
    fi

    echo "🚀 Spawning interactive hermes container..."
    docker run --rm $DOCKER_FLAGS \
        --env-file .env \
        -v "${WORKSPACE_DIR:-./workspace}:/workspace" \
        -v "${SCRIPT_DIR}/data/hermes:/opt/data" \
        "$HERMES_IMAGE"
    ;;

reset)
    if [[ "${2:-}" == "help" ]] || [[ "${2:-}" == "-h" ]]; then
        echo "Usage: $0 reset [services]"
        echo "  Reset data directories for services."
        echo ""
        echo "Examples:"
        echo "  $0 reset                # reset all services"
        echo "  $0 reset hermes        # reset only hermes"
        echo "  $0 reset hermes open-webui  # reset hermes and open-webui"
        exit 0
    fi

    SERVICES="${2:-hermes open-webui camofox-browser life360-mcp}"

    echo "⚠️  Resetting data directories..."

    # Backup .env files to .env.backup in same directory
    [[ -f .env ]] && cp .env .env.backup && echo "  💾 Backed up .env → .env.backup"

    for svc in $SERVICES; do
        case "$svc" in
            hermes)
                [[ -f data/hermes/.env ]] && cp data/hermes/.env data/hermes/.env.backup && echo "  💾 Backed up data/hermes/.env → data/hermes/.env.backup"
                rm -rf data/hermes/*
                mkdir -p data/hermes
                git checkout data/hermes/.gitkeep 2>/dev/null || true
                echo "  ✅ Reset data/hermes"
                ;;
            open-webui)
                [[ -f data/open-webui/.env ]] && cp data/open-webui/.env data/open-webui/.env.backup && echo "  💾 Backed up data/open-webui/.env → data/open-webui/.env.backup"
                rm -rf data/open-webui/*
                mkdir -p data/open-webui
                git checkout data/open-webui/.gitkeep data/open-webui/.env.example 2>/dev/null || true
                echo "  ✅ Reset data/open-webui"
                ;;
            camofox-browser)
                rm -rf data/camofox-browser/*
                mkdir -p data/camofox-browser
                git checkout data/camofox-browser/.gitkeep data/camofox-browser/.env.example 2>/dev/null || true
                echo "  ✅ Reset data/camofox-browser"
                ;;
            life360-mcp)
                [[ -f data/life360-mcp/.env ]] && cp data/life360-mcp/.env data/life360-mcp/.env.backup && echo "  💾 Backed up data/life360-mcp/.env → data/life360-mcp/.env.backup"
                rm -rf data/life360-mcp/*
                mkdir -p data/life360-mcp
                git checkout data/life360-mcp/.gitkeep data/life360-mcp/.env.example 2>/dev/null || true
                echo "  ✅ Reset data/life360-mcp"
                ;;
        esac
    done

    rm -f .env
    echo "  ✅ Removed .env"

    echo ""
    echo "✅ Reset complete. Run './hermes-stack setup' to reconfigure."
    ;;

setup)
    SUBCOMMAND="${2:-}"
    case "$SUBCOMMAND" in
        life360)
            setup_life360
            exit $?
            ;;
        help|-h)
            echo "Usage: $0 setup [life360]"
            echo "  Set up secrets in .env and run hermes setup in container."
            echo "  life360  - Interactive Life360 MCP configuration"
            exit 0
            ;;
    esac

    echo "⚙️  Setting up secrets..."

    if [[ ! -f .env ]] || ! grep -q "^WORKSPACE_DIR" .env 2>/dev/null; then
        if [[ -f .env.example ]]; then
            cp .env.example .env
            echo "  ✅ Created .env from template"
        fi
    fi

    if [[ ! -f data/hermes/.env ]]; then
        echo "CAMOFOX_URL=http://camofox-browser:9377" > data/hermes/.env
        echo "  ✅ Created data/hermes/.env with CAMOFOX_URL"
    fi

    for dir in data/*/; do
        if [[ -f "$dir/.env.example" ]] && [[ ! -f "$dir/.env" ]]; then
            cp "$dir/.env.example" "$dir/.env"
            echo "  ✅ Created $dir.env from template"
        fi
    done

    if [[ -z "${API_SERVER_KEY:-}" ]]; then
        API_SERVER_KEY=$(openssl rand -hex 32)
        if grep -q "^API_SERVER_KEY=" .env 2>/dev/null; then
            sed -i "s/^API_SERVER_KEY=.*/API_SERVER_KEY=$API_SERVER_KEY/" .env
        else
            echo "API_SERVER_KEY=$API_SERVER_KEY" >> .env
        fi
        echo "  ✅ Generated API_SERVER_KEY"
    else
        echo "  ℹ️  API_SERVER_KEY already set"
    fi

    echo "  ✅ Setting WEBUI_SECRET_KEY in data/open-webui/.env"
    WEBUI_SECRET_KEY=$(openssl rand -hex 32)
    if grep -q "^WEBUI_SECRET_KEY=" data/open-webui/.env 2>/dev/null; then
        sed -i "s/^WEBUI_SECRET_KEY=.*/WEBUI_SECRET_KEY=$WEBUI_SECRET_KEY/" data/open-webui/.env
    else
        echo "WEBUI_SECRET_KEY=$WEBUI_SECRET_KEY" >> data/open-webui/.env
    fi

    set -a && source .env && set +a

    echo ""
    echo "🚀 Running hermes setup in container..."

    if [[ -t 0 ]]; then
        DOCKER_FLAGS="-it"
    else
        DOCKER_FLAGS="-i"
    fi

    docker run --rm $DOCKER_FLAGS \
        --env-file .env \
        -v "${WORKSPACE_DIR:-./workspace}:/workspace" \
        -v "${SCRIPT_DIR}/data/hermes:/opt/data" \
        "$HERMES_IMAGE" \
        setup
    ;;

status)
    echo "=== Container status ==="
    docker compose ps
    ;;

# -------------------------------------------------
# Run interactive container
# -------------------------------------------------
run)
    ARGS="${2:-bash}"
    if [[ "$ARGS" == "help" ]] || [[ "$ARGS" == "-h" ]]; then
        echo "Usage: $0 run [command]"
        echo "  Spawn an interactive hermes container and run the given command."
        echo "  Default command: bash"
        echo ""
        echo "Examples:"
        echo "  $0 run              # interactive bash"
        echo "  $0 run opencode     # run opencode"
        echo "  $0 run pwd        # run pwd"
        exit 0
    fi

    echo "🚀 Spawning hermes container with: $ARGS"
    docker run --rm -it \
        --network hermesstack_hermesnet \
        --env-file .env \
        -v "${WORKSPACE_DIR:-./workspace}:/workspace" \
        -v "${SCRIPT_DIR}/data/hermes:/opt/data" \
        "$HERMES_IMAGE" \
        $ARGS
    ;;

# -------------------------------------------------
# Install
# -------------------------------------------------
install)
    TYPE="${2:-}"
    FORCE=0
    shift || true
    shift || true  # Skip "install" and get next arg
    for arg in "$@"; do
        [[ "$arg" == "--force" ]] && FORCE=1
    done

    case "$TYPE" in
        skills)
            echo "📂 Installing skills..."
            mkdir -p data/hermes/skills
            if [[ -d "skills" ]]; then
                # Copy each subdirectory recursively (e.g., skills/mcp/ -> data/hermes/skills/mcp/)
                for skill in skills/*/*/; do
                    skill_category=$(basename "$(dirname "$skill")")
                    skill_name=$(basename "$skill")
                    dest_dir="data/hermes/skills/$skill_category/$skill_name"
                    if [[ -d "$dest_dir" ]] && [[ $FORCE -eq 0 ]]; then
                        echo "  ⏭️  Skipping existing: $skill_category/$skill_name (use --force)"
                    else
                        mkdir -p "data/hermes/skills/$skill_category"
                        rm -rf "$dest_dir"  # Remove existing to avoid stale files
                        cp -r "$skill" "$dest_dir"
                        echo "  ✅ Installed: $skill_category/$skill_name"
                    fi
                done
                echo "Done installing skills."
                echo ""
                echo "ℹ️  If this skill requires configuration (e.g., MCP servers, API keys),"
                echo "   edit the relevant config files in data/hermes/"
                echo "ℹ️  Run './hermes-stack restart' to apply the new skill"
            else
                echo "No skills/ directory found in project root."
            fi
            ;;
        *)
            echo "Usage: $0 install skills [--force]"
            echo "  skills  - Install skills from ./skills/ to ./data/hermes/skills/"
            echo "  --force - Overwrite existing skills"
            ;;
    esac
    ;;

# -------------------------------------------------
# Backup / Restore (restored from your original)
# -------------------------------------------------
backup)
    # Default retain count (override via BACKUP_RETAIN_COUNT env var)
    RETAIN_COUNT=${BACKUP_RETAIN_COUNT:-7}
    DRY_RUN=0
    # Parse optional flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --retain)
                shift
                if [[ "$1" =~ ^[0-9]+$ ]]; then
                    RETAIN_COUNT="$1"
                else
                    echo "⚠️  Invalid retain count: $1 – using default 7"
                fi
                ;;
            --dry-run)
                DRY_RUN=1
                ;;
            *)
                echo "⚠️  Unknown backup option: $1"
                ;;
        esac
        shift
done

    BACKUP_DIR="${PWD}/backup"
    mkdir -p "$BACKUP_DIR"

    TS=$(date '+%Y%m%d_%H%M%S')
    ARCHIVE="${BACKUP_DIR}/hermes-stack_${TS}.tar.gz"

    echo "📦 Creating backup → $ARCHIVE"
    tar -czf "$ARCHIVE" data workspace 2>/dev/null
    echo "✅ Backup created."

    # Prune old backups, keep only the newest $RETAIN_COUNT files
    TOTAL=$(ls -1 $BACKUP_DIR/hermes-stack_*.tar.gz 2>/dev/null | wc -l)
    if [[ $TOTAL -gt $RETAIN_COUNT ]]; then
        NUM_TO_DELETE=$((TOTAL - RETAIN_COUNT))
        if [[ $DRY_RUN -eq 1 ]]; then
            echo "🧪 Dry‑run: the following $NUM_TO_DELETE backup(s) would be removed:"
            ls -1t $BACKUP_DIR/hermes-stack_*.tar.gz | tail -n $NUM_TO_DELETE
        else
            echo "🗑️  Pruning $NUM_TO_DELETE old backup(s) – keeping latest $RETAIN_COUNT"
            ls -1t $BACKUP_DIR/hermes-stack_*.tar.gz | tail -n $NUM_TO_DELETE | xargs -r rm --
            echo "✅ Prune complete: $NUM_TO_DELETE files removed, $RETAIN_COUNT newest retained."
        fi
    fi
    ;;

restore)
    read -p "Enter backup file (path): " f
    tar xzf "$f" -C .
    echo "Restored from $f"
    ;;

# -------------------------------------------------
# Docker cleanup (restored)
# -------------------------------------------------
prune)
    echo "🧹 Pruning unused Docker resources..."
    docker image prune -f
    docker volume prune -f
    echo "✅ Done"
    ;;

# -------------------------------------------------
# Env validation
# -------------------------------------------------
check-env)
    echo "Validating required environment variables..."
    MISSING=0

    [[ -f .env ]] && set -a && source .env && set +a
    [[ -f data/open-webui/.env ]] && set -a && source data/open-webui/.env && set +a

    for var in API_SERVER_KEY; do
        if [[ -z "${!var:-}" ]]; then
            echo "❌ $var missing in .env"
            ((MISSING++))
        else
            echo "✅ $var set"
        fi
    done

    if [[ -z "${WEBUI_SECRET_KEY:-}" ]]; then
        echo "❌ WEBUI_SECRET_KEY missing in data/open-webui/.env"
        ((MISSING++))
    else
        echo "✅ WEBUI_SECRET_KEY set"
    fi

    if (( MISSING )); then
        echo "Some variables are missing"
        exit 1
    else
        echo "All required variables are present."
    fi
    ;;

upgrade-base)
    echo "⬇️ Pulling latest base image..."
    docker pull "$BASE_IMAGE_NAME"

    echo "🌐 Remote digest:"
    get_remote_digest

    echo "💾 Local digest:"
    docker image inspect "$BASE_IMAGE_NAME" \
        --format='{{index .RepoDigests 0}}' \
        | cut -d'@' -f2
    ;;

help|--help|-h|"")
    print_help
    ;;

*)
    echo "Unknown command: $1"
    print_help
    exit 1
    ;;
esac
