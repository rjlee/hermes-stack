#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

BASE_IMAGE_NAME="nousresearch/hermes-agent:latest"
ROOT_ENV_FILE="$(pwd)/data/.env"

# Load environment variables
[[ -f "$ROOT_ENV_FILE" ]] && set -a && source "$ROOT_ENV_FILE" && set +a

# Determine Hermes image
HERMES_IMAGE="${HERMES_IMAGE:-nousresearch/hermes-agent:latest}"
export HERMES_IMAGE

print_help() {
cat <<'EOF'
hermes-stack – helper script for the hermes-stack project

Usage: $0 {up|down|logs|restart|backup|restore|prune|status|check-env|upgrade-base|install|help} [options]

Commands:
  up               Start the stack. Use --upgrade to pull latest images and rebuild Hermes.
  down             Stop and remove containers, networks and default volumes.
  logs             Follow live logs of all services.
  restart          Stop and start containers. Use --upgrade to pull latest and rebuild.
  profiles         List or apply model configurations (e.g., profiles free)
  backup [--retain N] [--dry-run]
                   Create a timestamped backup of data/ and workspace/.
                   The script automatically keeps only the most recent N
                   archives (default 7). Use --dry-run to list files that
                   would be pruned without deleting them.
  restore          Prompt for a backup file and extract it.
  prune            Remove unused Docker images and volumes.
  status           Show container status (health column).
  check-env        Validate required environment variables.
  upgrade-base     Pull the latest base image and display its digests.
  install skills   Install skills from ./skills/ to ./data/hermes/skills/
  cli             Spawn an interactive hermes container (CLI mode)
  setup [subcommand]  Set up secrets in .env and run hermes setup
                  todoist - Configure Todoist API and install todoist skills
                  life360 - Configure Life360 MCP and install location skills
                  google-workspace - Configure Google Workspace OAuth
  reset [services] Reset data directories (default: all services)
  help             Show this help message.
EOF
}

# -------------------------------------------------
# Digest helpers
# -------------------------------------------------
get_remote_digest() {
    docker manifest inspect "$BASE_IMAGE_NAME" 2>/dev/null \
        | grep -m1 '"digest"' \
        | awk -F'"' '{print $4}'
}

# -------------------------------------------------
# Google Workspace Setup
# -------------------------------------------------
setup_google_workspace()
{
    echo "📧 Google Workspace Configuration"
    echo ""
    echo "This command helps you set up Google Workspace (Gmail, Calendar, Drive, etc.)"
    echo "OAuth2 is required - you'll need to create credentials in Google Cloud Console."
    echo ""
    echo "=== Step 1: Create OAuth credentials in Google Cloud Console ==="
    echo "1. Go to: https://console.cloud.google.com/apis/credentials"
    echo "2. Click 'Create Credentials' → 'OAuth client ID'"
    echo "3. Application type: Select 'Web application'"
    echo "4. Name: 'Hermes Agent' (or any name you prefer)"
    echo "5. Authorized redirect URIs: Add 'http://localhost:1'"
    echo "6. Click 'Create'"
    echo "7. Download the JSON file (click 'Download JSON')"
    echo ""
    echo "=== Step 2: Choose services and permissions ==="
    echo "Available services:"
    echo "  - gmail     : Read/send emails"
    echo "  - calendar : Calendar events"
    echo "  - drive   : Drive files"
    echo "  - contacts: Google contacts"
    echo "  - docs    : Google Docs"
    echo "  - sheets  : Google Sheets"
    echo ""
    echo "Read-only scopes are available for gmail and drive (safer option)."
    echo ""
    echo "For full setup instructions, visit:"
    echo "  https://developers.google.com/workspace/guides/create-credentials"
    echo ""
    echo "=== Step 3: Provide credentials ==="
    read -p "Path to client_secret.json (or press Enter to skip): " CLIENT_SECRET
    if [[ -z "$CLIENT_SECRET" ]]; then
        echo "Skipped. Run this command again with the path when ready."
        return 0
    fi
    
    if [[ ! -f "$CLIENT_SECRET" ]]; then
        echo "  ❌ File not found: $CLIENT_SECRET"
        return 1
    fi
    
    echo ""
    echo "Which services do you need? (comma-separated, or 'all'):"
    read -p "[all]: " SERVICES
    SERVICES="${SERVICES:-all}"
    
    echo ""
    echo "Use read-only scopes? (recommended for safety):"
    read -p "[y/N]: " READONLY
    READONLY="${READONLY:-n}"
    
    ENV_FILE="data/hermes/.env"
    if [[ ! -f "$ENV_FILE" ]]; then
        echo "# Hermes environment" > "$ENV_FILE"
    fi
    
    if [[ -f "$CLIENT_SECRET" ]]; then
        mkdir -p data/hermes/.google
        cp "$CLIENT_SECRET" data/hermes/.google/client_secret.json
        # Also copy to /opt/data for the google-workspace skill
        cp "$CLIENT_SECRET" data/hermes/google_client_secret.json
        echo "  ✅ Saved client credentials to data/hermes/.google/"
        # Fix permissions
        chown -R 1000:1000 data/hermes/.google data/hermes/google_client_secret.json 2>/dev/null || true
        
        grep -q "^GOOGLE_SETUP_SERVICES=" "$ENV_FILE" || echo "GOOGLE_SETUP_SERVICES=$SERVICES" >> "$ENV_FILE"
        if [[ "$READONLY" == "y" ]] || [[ "$READONLY" == "Y" ]]; then
            grep -q "^GOOGLE_READONLY=" "$ENV_FILE" || echo "GOOGLE_READONLY=true" >> "$ENV_FILE"
        fi
        echo "  ✅ Configuration saved"
        echo ""
        echo "Next steps:"
        echo "  1. Run: docker exec -e PYTHONPATH=/opt/hermes hermes-stack-hermes-1 python3 \\"
        echo "       /opt/data/skills/productivity/google-workspace/scripts/setup.py --auth-url"
        echo "  2. Copy the URL shown, open in browser, authorize"
        echo "  3. Copy the code shown, run:"
        echo "     docker exec -e PYTHONPATH=/opt/hermes hermes-stack-hermes-1 python3 \\"
        echo "       /opt/data/skills/productivity/google-workspace/scripts/setup.py --auth-code CODE"
        echo "  4. Restart hermes: docker compose restart hermes"
    else
        echo "  ❌ Invalid path"
        return 1
    fi
    
    echo ""
    read -p "Restart hermes now? [y/N]: " RESTART
    if [[ "$RESTART" == "y" ]] || [[ "$RESTART" == "Y" ]]; then
        echo ""
        echo "Restarting hermes..."
        docker compose restart hermes
    fi
}

# -------------------------------------------------
# Life360 Setup
# -------------------------------------------------
setup_life360()
{
    echo "📍 Life360 MCP Configuration"
    echo ""
    echo "Choose authentication method:"
    echo "  1) Skip (configure manually later)"
    echo "  2) Authorization token (from Life360 app)"
    echo "  3) Username + Password (OAuth)"
    echo ""
    read -p "Enter choice [1]: " CHOICE
    CHOICE="${CHOICE:-1}"

    ENV_FILE="data/hermes/.env"

    if [[ "$CHOICE" == "1" ]] || [[ "$CHOICE" == "skip" ]]; then
        echo "Skipped. Edit $ENV_FILE manually when ready."
        return 0
    fi

    echo ""

    if [[ "$CHOICE" == "2" ]]; then
        read -p "Authorization token: " LIFE360_AUTHORIZATION
        if [[ -n "$LIFE360_AUTHORIZATION" ]]; then
            # Add to hermes .env (create file if needed)
            if [[ ! -f "$ENV_FILE" ]]; then
                echo "# Hermes environment" > "$ENV_FILE"
            fi
            grep -q "^LIFE360_AUTHORIZATION=" "$ENV_FILE" && \
                sed -i "s/^LIFE360_AUTHORIZATION=.*/LIFE360_AUTHORIZATION=$LIFE360_AUTHORIZATION/" "$ENV_FILE" || \
                echo "LIFE360_AUTHORIZATION=$LIFE360_AUTHORIZATION" >> "$ENV_FILE"
            grep -q "^LIFE360_TOKEN_TYPE=" "$ENV_FILE" || echo "LIFE360_TOKEN_TYPE=Bearer" >> "$ENV_FILE"
            echo "  ✅ Saved authorization token to $ENV_FILE"
        fi
    elif [[ "$CHOICE" == "3" ]]; then
        read -p "Username (email): " LIFE360_USERNAME
        read -s -p "Password: " LIFE360_PASSWORD
        echo ""
        if [[ -n "$LIFE360_USERNAME" ]] && [[ -n "$LIFE360_PASSWORD" ]]; then
            if [[ ! -f "$ENV_FILE" ]]; then
                echo "# Hermes environment" > "$ENV_FILE"
            fi
            grep -q "^LIFE360_USERNAME=" "$ENV_FILE" || echo "LIFE360_USERNAME=$LIFE360_USERNAME" >> "$ENV_FILE"
            grep -q "^LIFE360_PASSWORD=" "$ENV_FILE" || echo "LIFE360_PASSWORD=$LIFE360_PASSWORD" >> "$ENV_FILE"
            grep -q "^LIFE360_CLIENT_ID=" "$ENV_FILE" || echo "LIFE360_CLIENT_ID=life360_mobile_app" >> "$ENV_FILE"
            echo "  ✅ Saved username/password to $ENV_FILE"
        fi
    else
        echo "Invalid choice: $CHOICE"
        return 1
    fi

    echo ""
    read -p "Restart hermes-stack now? [y/N]: " RESTART
    if [[ "$RESTART" == "y" ]] || [[ "$RESTART" == "Y" ]]; then
        echo ""
        echo "Restarting hermes container..."
        docker compose restart hermes
    fi
}

# -------------------------------------------------
# Todoist Setup
# -------------------------------------------------
setup_todoist()
{
    echo "📝 Todoist Configuration"
    echo ""
    
    ENV_FILE="data/hermes/.env"
    
    read -p "Enter your Todoist API token: " TODOIST_API_TOKEN
    if [[ -n "$TODOIST_API_TOKEN" ]]; then
        if grep -q "^TODOIST_API_TOKEN=" "$ENV_FILE" 2>/dev/null; then
            sed -i "s/^TODOIST_API_TOKEN=.*/TODOIST_API_TOKEN=$TODOIST_API_TOKEN/" "$ENV_FILE"
            echo "  ✅ Updated TODOIST_API_TOKEN"
        else
            echo "TODOIST_API_TOKEN=$TODOIST_API_TOKEN" >> "$ENV_FILE"
            echo "  ✅ Saved TODOIST_API_TOKEN"
        fi
    else
        echo "No token entered. Skipped."
        return 1
    fi
    
    echo ""
    read -p "Restart hermes-stack now? [y/N]: " RESTART
    if [[ "$RESTART" == "y" ]] || [[ "$RESTART" == "Y" ]]; then
        echo ""
        echo "Restarting hermes..."
        docker compose restart hermes
    fi
}

# -------------------------------------------------
# Commands
# -------------------------------------------------
case "${1:-}" in

up)
    UPGRADE=0
    shift || true
    for arg in "$@"; do
        [[ "$arg" == "--upgrade" ]] && UPGRADE=1
    done

    if [[ $UPGRADE -eq 1 ]]; then
        docker compose pull
    fi

    docker compose up -d
    ;;

restart)
    UPGRADE=0
    shift || true
    for arg in "$@"; do
        [[ "$arg" == "--upgrade" ]] && UPGRADE=1
    done

    docker compose down

    if [[ $UPGRADE -eq 1 ]]; then
        docker compose pull
    fi

    docker compose up -d
    ;;

# -------------------------------------------------
# Profiles - manage model configurations
# -------------------------------------------------
profiles)
    PROFILE_ACTION="${2:-list}"
    
    if [[ "$PROFILE_ACTION" == "list" ]] || [[ -z "$PROFILE_ACTION" ]]; then
        echo "Available profiles:"
        for f in profiles/*.yaml; do
            if [[ -f "$f" ]]; then
                NAME=$(basename "$f" .yaml)
                DESC=$(grep "^description:" "$f" 2>/dev/null | sed 's/description: //')
                echo "  - $NAME${DESC:+: $DESC}"
            fi
        done
        echo ""
        echo "Usage: $0 profiles <name>  # Apply a profile"
        exit 0
    fi
    
    PROFILE_FILE="profiles/${PROFILE_ACTION}.yaml"
    
    if [[ ! -f "$PROFILE_FILE" ]]; then
        echo "Profile not found: $PROFILE_ACTION"
        echo "Run '$0 profiles list' for available profiles."
        exit 1
    fi
    
    echo "Applying profile: $PROFILE_ACTION"
    
    mkdir -p data/hermes/.hermes-stack/profiles
    cp -f "$PROFILE_FILE" "data/hermes/.hermes-stack/profiles/"
    
    docker compose exec hermes python3 -c "
import yaml
import sys

config_file = '/opt/data/config.yaml'
profile_file = '/opt/data/.hermes-stack/profiles/${PROFILE_ACTION}.yaml'

try:
    with open(config_file) as f:
        config = yaml.safe_load(f)
except Exception as e:
    print(f'Error loading config: {e}', file=sys.stderr)
    sys.exit(1)

try:
    with open(profile_file) as f:
        profile = yaml.safe_load(f)
except Exception as e:
    print(f'Error loading profile: {e}', file=sys.stderr)
    sys.exit(1)

for key in ['model', 'embedding', 'tts', 'stt']:
    if key in profile:
        config[key] = profile[key]
        value = profile[key]
        if isinstance(value, dict):
            for k, v in value.items():
                config.setdefault(key, {})[k] = v
        else:
            config[key] = value
        print(f'  Set {key}: {value.get(\"model\", value) if isinstance(value, dict) else value}')

try:
    with open(config_file, 'w') as f:
        yaml.dump(config, f, default_flow_style=False)
except Exception as e:
    print(f'Error saving config: {e}', file=sys.stderr)
    sys.exit(1)

print('Profile applied!')
"
    
    echo "Run './hermes-stack restart' to apply changes."
    ;;

down)
    docker compose down
    ;;

logs)
    docker compose logs -f
    ;;

cli)
    if [[ "${2:-}" == "help" ]] || [[ "${2:-}" == "-h" ]]; then
        echo "Usage: $0 cli"
        echo "  Spawn an interactive hermes container (CLI mode)."
        exit 0
    fi

    if [[ -t 0 ]]; then
        DOCKER_FLAGS="-it"
    else
        DOCKER_FLAGS="-i"
    fi

    echo "🚀 Spawning interactive hermes container..."
    docker run --rm $DOCKER_FLAGS \
        --env-file "$ROOT_ENV_FILE" \
        -v "${WORKSPACE_DIR:-./workspace}:/workspace" \
        -v "${SCRIPT_DIR}/data/hermes:/opt/data" \
        "$HERMES_IMAGE"
    ;;

reset)
    if [[ "${2:-}" == "help" ]] || [[ "${2:-}" == "-h" ]]; then
        echo "Usage: $0 reset [services]"
        echo "  Reset data directories for services."
        echo ""
        echo "Examples:"
        echo "  $0 reset                # reset all services"
        echo "  $0 reset hermes        # reset only hermes"
        echo "  $0 reset hermes open-webui  # reset hermes and open-webui"
        exit 0
    fi

    SERVICES="${2:-hermes open-webui camofox-browser life360-mcp}"

    echo "⚠️  Resetting data directories..."

    for svc in $SERVICES; do
        case "$svc" in
            hermes)
                # Backup .env before deleting data
                [[ -f data/hermes/.env ]] && mv data/hermes/.env data/hermes/.env.backup && echo "  💾 Backed up data/hermes/.env → data/hermes/.env.backup"
                rm -rf data/hermes/*
                mkdir -p data/hermes
                git checkout data/hermes/.gitkeep 2>/dev/null || true
                echo "  ✅ Reset data/hermes"
                ;;
            open-webui)
                [[ -f data/open-webui/.env ]] && mv data/open-webui/.env data/open-webui/.env.backup && echo "  💾 Backed up data/open-webui/.env → data/open-webui/.env.backup"
                sudo rm -rf data/open-webui/*
                mkdir -p data/open-webui
                git checkout data/open-webui/.gitkeep data/open-webui/.env.example 2>/dev/null || true
                echo "  ✅ Reset data/open-webui"
                ;;
            camofox-browser)
                [[ -f data/camofox-browser/.env ]] && mv data/camofox-browser/.env data/camofox-browser/.env.backup && echo "  💾 Backed up data/camofox-browser/.env → data/camofox-browser/.env.backup"
                rm -rf data/camofox-browser/*
                mkdir -p data/camofox-browser
                git checkout data/camofox-browser/.gitkeep data/camofox-browser/.env.example 2>/dev/null || true
                echo "  ✅ Reset data/camofox-browser"
                ;;
            life360-mcp)
                [[ -f data/life360-mcp/.env ]] && mv data/life360-mcp/.env data/life360-mcp/.env.backup && echo "  💾 Backed up data/life360-mcp/.env → data/life360-mcp/.env.backup"
                rm -rf data/life360-mcp/*
                mkdir -p data/life360-mcp
                git checkout data/life360-mcp/.gitkeep data/life360-mcp/.env.example 2>/dev/null || true
                echo "  ✅ Reset data/life360-mcp"
                ;;
        esac
    done

    # Also backup root .env
    [[ -f "$ROOT_ENV_FILE" ]] && mv "$ROOT_ENV_FILE" "${ROOT_ENV_FILE}.backup" && echo "  💾 Backed up data/.env → data/.env.backup"

    # Recreate from template
    cp .env.example "$ROOT_ENV_FILE" 2>/dev/null || git checkout .env.example 2>/dev/null || true

    echo ""
    echo "✅ Reset complete. Run './hermes-stack setup' to reconfigure."
    ;;

setup)
    SUBCOMMAND="${2:-}"
    case "$SUBCOMMAND" in
        life360)
            setup_life360
            RET=$?
            
            if [[ -d "skills/life360" ]]; then
                mkdir -p data/life360-mcp/skills
                cp -r skills/life360/. data/life360-mcp/skills/
                echo "  ✅ Installed life360 skills"
            fi
            # Copy hints for memory seeding
            if [[ -f "skills/life360/hints" ]]; then
                mkdir -p data/hermes/.hermes-stack/hints
                cp skills/life360/hints data/hermes/.hermes-stack/hints/location-query
                echo "  ✅ Installed life360 hints"
            fi
            exit $RET
            ;;
        todoist)
            setup_todoist
            
            if [[ -d "skills/todoist" ]]; then
                mkdir -p data/hermes/skills/productivity/todoist
                cp -r skills/todoist/task-query data/hermes/skills/productivity/todoist/
                echo "  ✅ Installed todoist skills to data/hermes/"
                echo "  ℹ️  Restart hermes container to apply new skills"
            else
                echo "  ⚠️ No skills/todoist/ directory found"
            fi
            # Copy hints for memory seeding
            if [[ -f "skills/todoist/hints" ]]; then
                mkdir -p data/hermes/.hermes-stack/hints
                cp skills/todoist/hints data/hermes/.hermes-stack/hints/task-query
                echo "  ✅ Installed todoist hints"
            fi
            exit 0
            ;;
        google-workspace)
            setup_google_workspace
            # Copy hints for memory seeding
            if [[ -f "skills/google-workspace/hints" ]]; then
                mkdir -p data/hermes/.hermes-stack/hints
                cp skills/google-workspace/hints data/hermes/.hermes-stack/hints/google-workspace
                echo "  ✅ Installed google-workspace hints"
            fi
            exit $?
            ;;
        help|-h)
            echo "Usage: $0 setup [container]"
            echo "  setup              - Set up .env files, generate secrets, run hermes setup"
            echo "  setup todoist      - Configure Todoist API and install todoist skills"
            echo "  setup life360     - Configure Life360 MCP and install location skills"
            echo "  setup google-workspace - Configure Google Workspace OAuth"
            exit 0
            ;;
    esac

    echo "⚙️  Setting up secrets..."

    if [[ ! -f "$ROOT_ENV_FILE" ]] || ! grep -q "^WORKSPACE_DIR" "$ROOT_ENV_FILE" 2>/dev/null; then
        if [[ -f .env.example ]]; then
            cp .env.example "$ROOT_ENV_FILE"
            echo "  ✅ Created data/.env from template"
        fi
    fi

    if [[ ! -f data/hermes/.env ]]; then
        echo "CAMOFOX_URL=http://camofox-browser:9377" > data/hermes/.env
        echo "  ✅ Created data/hermes/.env with CAMOFOX_URL"
    fi

    for dir in data/*/; do
        if [[ -f "$dir/.env.example" ]] && [[ ! -f "$dir/.env" ]]; then
            cp "$dir/.env.example" "$dir/.env"
            echo "  ✅ Created $dir.env from template"
        fi
    done

    if [[ -z "${API_SERVER_KEY:-}" ]]; then
        API_SERVER_KEY=$(openssl rand -hex 32)
        # Remove ANY line containing API_SERVER_KEY from .env
        cat "$ROOT_ENV_FILE" | grep -v "API_SERVER_KEY" > "${ROOT_ENV_FILE}.new"
        mv "${ROOT_ENV_FILE}.new" "$ROOT_ENV_FILE"
        # Add new key
        echo "API_SERVER_KEY=$API_SERVER_KEY" >> "$ROOT_ENV_FILE"
        echo "  ✅ Generated API_SERVER_KEY"
    else
        echo "  ℹ️  API_SERVER_KEY already set"
    fi

    echo "  ✅ Setting WEBUI_SECRET_KEY in data/open-webui/.env"
    WEBUI_SECRET_KEY=$(openssl rand -hex 32)
    if grep -q "^WEBUI_SECRET_KEY=" data/open-webui/.env 2>/dev/null; then
        sed -i "s/^WEBUI_SECRET_KEY=.*/WEBUI_SECRET_KEY=$WEBUI_SECRET_KEY/" data/open-webui/.env
    else
        echo "WEBUI_SECRET_KEY=$WEBUI_SECRET_KEY" >> data/open-webui/.env
    fi

    set -a && source "$ROOT_ENV_FILE" && set +a

    echo ""
    echo "🚀 Running hermes setup in container..."

    if [[ -t 0 ]]; then
        DOCKER_FLAGS="-it"
    else
        DOCKER_FLAGS="-i"
    fi

    docker run --rm $DOCKER_FLAGS \
        --user "1000:1000" \
        --env-file "$ROOT_ENV_FILE" \
        -v "${WORKSPACE_DIR:-./workspace}:/workspace" \
        -v "${SCRIPT_DIR}/data/hermes:/opt/data" \
        "$HERMES_IMAGE" \
        setup

    # Fix ownership after hermes setup
    chown -R "$(id -u):$(id -g)" "${SCRIPT_DIR}/data/hermes" 2>/dev/null || true
    ;;

status)
    echo "=== Container status ==="
    docker compose ps
    ;;

# -------------------------------------------------
# Run interactive container
# -------------------------------------------------
run)
    ARGS="${2:-bash}"
    if [[ "$ARGS" == "help" ]] || [[ "$ARGS" == "-h" ]]; then
        echo "Usage: $0 run [command]"
        echo "  Spawn an interactive hermes container and run the given command."
        echo "  Default command: bash"
        echo ""
        echo "Examples:"
        echo "  $0 run              # interactive bash"
        echo "  $0 run opencode     # run opencode"
        echo "  $0 run pwd        # run pwd"
        exit 0
    fi

    echo "🚀 Spawning hermes container with: $ARGS"
    docker run --rm -it \
        --network hermesstack_hermesnet \
        --env-file "$ROOT_ENV_FILE" \
        -v "${WORKSPACE_DIR:-./workspace}:/workspace" \
        -v "${SCRIPT_DIR}/data/hermes:/opt/data" \
        "$HERMES_IMAGE" \
        $ARGS
    ;;

# -------------------------------------------------
# Install
# -------------------------------------------------
install)
    TYPE="${2:-}"
    FORCE=0
    shift || true
    shift || true  # Skip "install" and get next arg
    for arg in "$@"; do
        [[ "$arg" == "--force" ]] && FORCE=1
    done

    case "$TYPE" in
        skills)
            echo "📂 Installing skills..."
            mkdir -p data/hermes/skills
            if [[ -d "skills" ]]; then
                # Copy each subdirectory recursively (e.g., skills/mcp/ -> data/hermes/skills/mcp/)
                for skill in skills/*/*/; do
                    skill_category=$(basename "$(dirname "$skill")")
                    skill_name=$(basename "$skill")
                    dest_dir="data/hermes/skills/$skill_category/$skill_name"
                    if [[ -d "$dest_dir" ]] && [[ $FORCE -eq 0 ]]; then
                        echo "  ⏭️  Skipping existing: $skill_category/$skill_name (use --force)"
                    else
                        mkdir -p "data/hermes/skills/$skill_category"
                        rm -rf "$dest_dir"  # Remove existing to avoid stale files
                        cp -r "$skill" "$dest_dir"
                        echo "  ✅ Installed: $skill_category/$skill_name"
                    fi
                done
                echo "Done installing skills."
                echo ""
                echo "ℹ️  If this skill requires configuration (e.g., MCP servers, API keys),"
                echo "   edit the relevant config files in data/hermes/"
                echo "ℹ️  Run './hermes-stack restart' to apply the new skill"
            else
                echo "No skills/ directory found in project root."
            fi
            ;;
        *)
            echo "Usage: $0 install skills [--force]"
            echo "  skills  - Install skills from ./skills/ to ./data/hermes/skills/"
            echo "  --force - Overwrite existing skills"
            ;;
    esac
    ;;

# -------------------------------------------------
# Backup / Restore (restored from your original)
# -------------------------------------------------
backup)
    # Default retain count (override via BACKUP_RETAIN_COUNT env var)
    RETAIN_COUNT=${BACKUP_RETAIN_COUNT:-7}
    DRY_RUN=0
    # Parse optional flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --retain)
                shift
                if [[ "$1" =~ ^[0-9]+$ ]]; then
                    RETAIN_COUNT="$1"
                else
                    echo "⚠️  Invalid retain count: $1 – using default 7"
                fi
                ;;
            --dry-run)
                DRY_RUN=1
                ;;
            *)
                echo "⚠️  Unknown backup option: $1"
                ;;
        esac
        shift
done

    BACKUP_DIR="${PWD}/backup"
    mkdir -p "$BACKUP_DIR"

    TS=$(date '+%Y%m%d_%H%M%S')
    ARCHIVE="${BACKUP_DIR}/hermes-stack_${TS}.tar.gz"

    echo "📦 Creating backup → $ARCHIVE"
    tar -czf "$ARCHIVE" data workspace 2>/dev/null
    echo "✅ Backup created."

    # Prune old backups, keep only the newest $RETAIN_COUNT files
    TOTAL=$(ls -1 $BACKUP_DIR/hermes-stack_*.tar.gz 2>/dev/null | wc -l)
    if [[ $TOTAL -gt $RETAIN_COUNT ]]; then
        NUM_TO_DELETE=$((TOTAL - RETAIN_COUNT))
        if [[ $DRY_RUN -eq 1 ]]; then
            echo "🧪 Dry‑run: the following $NUM_TO_DELETE backup(s) would be removed:"
            ls -1t $BACKUP_DIR/hermes-stack_*.tar.gz | tail -n $NUM_TO_DELETE
        else
            echo "🗑️  Pruning $NUM_TO_DELETE old backup(s) – keeping latest $RETAIN_COUNT"
            ls -1t $BACKUP_DIR/hermes-stack_*.tar.gz | tail -n $NUM_TO_DELETE | xargs -r rm --
            echo "✅ Prune complete: $NUM_TO_DELETE files removed, $RETAIN_COUNT newest retained."
        fi
    fi
    ;;

restore)
    read -p "Enter backup file (path): " f
    tar xzf "$f" -C .
    echo "Restored from $f"
    ;;

# -------------------------------------------------
# Docker cleanup (restored)
# -------------------------------------------------
prune)
    echo "🧹 Pruning unused Docker resources..."
    docker image prune -f
    docker volume prune -f
    echo "✅ Done"
    ;;

# -------------------------------------------------
# Env validation
# -------------------------------------------------
check-env)
    echo "Validating required environment variables..."
    MISSING=0

ROOT_ENV_FILE="data/.env"
ENVS_DIR="$(pwd)/data"

[[ -f "$ROOT_ENV_FILE" ]] && set -a && source "$ROOT_ENV_FILE" && set +a
    [[ -f data/open-webui/.env ]] && set -a && source data/open-webui/.env && set +a

    for var in API_SERVER_KEY; do
        if [[ -z "${!var:-}" ]]; then
            echo "❌ $var missing in .env"
            ((MISSING++))
        else
            echo "✅ $var set"
        fi
    done

    if [[ -z "${WEBUI_SECRET_KEY:-}" ]]; then
        echo "❌ WEBUI_SECRET_KEY missing in data/open-webui/.env"
        ((MISSING++))
    else
        echo "✅ WEBUI_SECRET_KEY set"
    fi

    if (( MISSING )); then
        echo "Some variables are missing"
        exit 1
    else
        echo "All required variables are present."
    fi
    ;;

upgrade-base)
    echo "⬇️ Pulling latest base image..."
    docker pull "$BASE_IMAGE_NAME"

    echo "🌐 Remote digest:"
    get_remote_digest

    echo "💾 Local digest:"
    docker image inspect "$BASE_IMAGE_NAME" \
        --format='{{index .RepoDigests 0}}' \
        | cut -d'@' -f2
    ;;

help|--help|-h|"")
    print_help
    ;;

*)
    echo "Unknown command: $1"
    print_help
    exit 1
    ;;
esac
