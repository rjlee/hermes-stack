        echo ""
        echo "Restarting hermes..."
        $DOCKER_COMPOSE restart hermes
    fi
}

# -------------------------------------------------
# Commands
# -------------------------------------------------
case "${1:-}" in

up)
    UPGRADE=0
    shift || true
    for arg in "$@"; do
        [[ "$arg" == "--upgrade" ]] && UPGRADE=1
    done

    if [[ $UPGRADE -eq 1 ]]; then
        $DOCKER_COMPOSE pull
    fi

    $DOCKER_COMPOSE up -d --wait
    ;;

restart)
    UPGRADE=0
    shift || true
    for arg in "$@"; do
        [[ "$arg" == "--upgrade" ]] && UPGRADE=1
    done

    $DOCKER_COMPOSE down

    if [[ $UPGRADE -eq 1 ]]; then
        $DOCKER_COMPOSE pull
    fi

    $DOCKER_COMPOSE up -d --wait
    ;;

# -------------------------------------------------
# Model - manage model configurations
# -------------------------------------------------
model)
    PROFILE_ACTION="${2:-list}"
    
    if [[ "$PROFILE_ACTION" == "list" ]] || [[ -z "$PROFILE_ACTION" ]]; then
        echo "Available models:"
        for f in models/*.yaml; do
            if [[ -f "$f" ]]; then
                NAME=$(basename "$f" .yaml)
                DESC=$(grep "^description:" "$f" 2>/dev/null | sed 's/description: //')
                echo "  - $NAME${DESC:+: $DESC}"
            fi
        done
        echo ""
        echo "Usage: $0 model <name>  # Apply a model"
        exit 0
    fi
    
    MODEL_FILE="models/${PROFILE_ACTION}.yaml"
    
    if [[ ! -f "$MODEL_FILE" ]]; then
        echo "Model not found: $PROFILE_ACTION"
        echo "Run '$0 model list' for available models."
        exit 1
    fi
    
    echo "Applying model: $PROFILE_ACTION"
    
    mkdir -p data/hermes/.hermes-stack/models
    cp -f "$MODEL_FILE" "data/hermes/.hermes-stack/models/"
    
    $DOCKER_COMPOSE exec hermes python3 -c "
import yaml
import sys

config_file = '/opt/data/config.yaml'
model_file = '/opt/data/.hermes-stack/models/${PROFILE_ACTION}.yaml'

try:
    with open(config_file) as f:
        config = yaml.safe_load(f)
except Exception as e:
    print(f'Error loading config: {e}', file=sys.stderr)
    sys.exit(1)

try:
    with open(model_file) as f:
        m = yaml.safe_load(f)
except Exception as e:
    print(f'Error loading model: {e}', file=sys.stderr)
    sys.exit(1)

for key in ['model', 'embedding', 'tts', 'stt']:
    if key in m:
        config[key] = m[key]
        val = m[key]
        if isinstance(val, dict):
            for k, v in val.items():
                config.setdefault(key, {})[k] = v
        else:
            config[key] = val
        print(f'  Set {key}: {val}')

try:
    with open(config_file, 'w') as f:
        yaml.dump(config, f, default_flow_style=False)
except Exception as e:
    print(f'Error saving config: {e}', file=sys.stderr)
    sys.exit(1)

print('Model applied!')
"
    
    echo "Run './hermes-stack restart' to apply changes."
    ;;

down)
    $DOCKER_COMPOSE down
    ;;

logs)
    $DOCKER_COMPOSE logs -f
    ;;

cli)
    if [[ "${2:-}" == "help" ]] || [[ "${2:-}" == "-h" ]]; then
        echo "Usage: $0 cli"
        echo "  Spawn an interactive hermes container (CLI mode)."
        exit 0
    fi

    if [[ -t 0 ]]; then
        DOCKER_FLAGS="-it"
    else
        DOCKER_FLAGS="-i"
    fi

    echo "🚀 Spawning interactive hermes container..."
    docker run --rm $DOCKER_FLAGS \
        --user "10000:10000" \
        --network "$HERMES_NETWORK" \
        --entrypoint /opt/hermes/.venv/bin/hermes \
        -e HOME=/opt/data \
        --env-file "$ROOT_ENV_FILE" \
        -v "${WORKSPACE_DIR:-./workspace}:/workspace" \
        -v "${SCRIPT_DIR}/data/hermes:/opt/data" \
        "$HERMES_IMAGE" \
        --cli
    ;;

reset)
    if [[ "${2:-}" == "help" ]] || [[ "${2:-}" == "-h" ]]; then
        echo "Usage: $0 reset [services]"
        echo "  Reset data directories for services."
        echo ""
        echo "Examples:"
        echo "  $0 reset                # reset all services"
        echo "  $0 reset hermes        # reset only hermes"
        echo "  $0 reset hermes open-webui  # reset hermes and open-webui"
        exit 0
    fi

    SERVICES="${2:-hermes open-webui camofox-browser life360-mcp}"

    echo "⚠️  Resetting data directories..."

    for svc in $SERVICES; do
        case "$svc" in
            hermes)
                # Backup .env before deleting data
                [[ -f data/hermes/.env ]] && mv data/hermes/.env data/hermes/.env.backup && echo "  💾 Backed up data/hermes/.env → data/hermes/.env.backup"
                rm -rf data/hermes/*
                mkdir -p data/hermes
                git checkout data/hermes/.gitkeep 2>/dev/null || true
                echo "  ✅ Reset data/hermes"
                ;;
            open-webui)
                [[ -f data/open-webui/.env ]] && mv data/open-webui/.env data/open-webui/.env.backup && echo "  💾 Backed up data/open-webui/.env → data/open-webui/.env.backup"
                rm -rf data/open-webui/*
                mkdir -p data/open-webui
                git checkout data/open-webui/.gitkeep data/open-webui/.env.example 2>/dev/null || true
                echo "  ✅ Reset data/open-webui"
                ;;
            camofox-browser)
                [[ -f data/camofox-browser/.env ]] && mv data/camofox-browser/.env data/camofox-browser/.env.backup && echo "  💾 Backed up data/camofox-browser/.env → data/camofox-browser/.env.backup"
                rm -rf data/camofox-browser/*
                mkdir -p data/camofox-browser
                git checkout data/camofox-browser/.gitkeep data/camofox-browser/.env.example 2>/dev/null || true
                echo "  ✅ Reset data/camofox-browser"
                ;;
            life360-mcp)
                [[ -f data/life360-mcp/.env ]] && mv data/life360-mcp/.env data/life360-mcp/.env.backup && echo "  💾 Backed up data/life360-mcp/.env → data/life360-mcp/.env.backup"
                rm -rf data/life360-mcp/*
                mkdir -p data/life360-mcp
                git checkout data/life360-mcp/.gitkeep data/life360-mcp/.env.example 2>/dev/null || true
                echo "  ✅ Reset data/life360-mcp"
                ;;
        esac
    done

    # Also backup root .env
    [[ -f "$ROOT_ENV_FILE" ]] && mv "$ROOT_ENV_FILE" "${ROOT_ENV_FILE}.backup" && echo "  💾 Backed up data/.env → data/.env.backup"

    # Recreate from template
    cp .env.example "$ROOT_ENV_FILE" 2>/dev/null || git checkout .env.example 2>/dev/null || true

    echo ""
    echo "✅ Reset complete. Run './hermes-stack setup' to reconfigure."
    ;;

setup)
    SUBCOMMAND="${2:-}"
    case "$SUBCOMMAND" in
        life360)
            setup_life360
            RET=$?
            
            if [[ -d "skills/life360" ]]; then
                mkdir -p data/life360-mcp/skills
                cp -r skills/life360/. data/life360-mcp/skills/
                echo "  ✅ Installed life360 skills"
            fi
            # Copy hints for memory seeding
            if [[ -f "skills/life360/location-query/hints" ]]; then
                mkdir -p data/hermes/.hermes-stack/hints
                cp skills/life360/location-query/hints data/hermes/.hermes-stack/hints/location-query
                echo "  ✅ Installed life360 hints"
            fi
            # Copy install script for bootstrap
            if [[ -f "skills/life360/location-query/install.sh" ]]; then
                mkdir -p data/hermes/.hermes-stack/bootstrap
                cp skills/life360/location-query/install.sh data/hermes/.hermes-stack/bootstrap/location-query.sh
                echo "  ✅ Installed life360 install script"
            fi
            exit $RET
            ;;
        todoist)
            setup_todoist
            
            if [[ -d "skills/todoist" ]]; then
                mkdir -p data/hermes/skills/productivity/todoist
                cp -r skills/todoist/task-query data/hermes/skills/productivity/todoist/
                echo "  ✅ Installed todoist skills to data/hermes/"
                echo "  ℹ️  Restart hermes container to apply new skills"
            else
                echo "  ⚠️ No skills/todoist/ directory found"
            fi
            # Copy hints for memory seeding
            if [[ -f "skills/todoist/task-query/hints" ]]; then
                mkdir -p data/hermes/.hermes-stack/hints
                cp skills/todoist/task-query/hints data/hermes/.hermes-stack/hints/task-query
                echo "  ✅ Installed todoist hints"
            fi
            # Copy install script for bootstrap
            if [[ -f "skills/todoist/task-query/install.sh" ]]; then
                mkdir -p data/hermes/.hermes-stack/bootstrap
                cp skills/todoist/task-query/install.sh data/hermes/.hermes-stack/bootstrap/task-query.sh
                echo "  ✅ Installed todoist install script"
            fi
            exit 0
            ;;
        google-workspace)
            setup_google_workspace
            # Copy hints for memory seeding
            if [[ -f "skills/google-workspace/hints" ]]; then
                mkdir -p data/hermes/.hermes-stack/hints
                cp skills/google-workspace/hints data/hermes/.hermes-stack/hints/google-workspace
                echo "  ✅ Installed google-workspace hints"
            fi
            exit $?
            ;;
        help|-h)
            echo "Usage: $0 setup [subcommand]"
            echo "  setup              - Set up .env files, generate secrets, run hermes setup"
            echo "  setup todoist      - Configure Todoist API and install todoist skills"
            echo "  setup life360     - Configure Life360 MCP and install location skills"
            echo "  setup google-workspace - Configure Google Workspace OAuth"
            exit 0
            ;;
    esac

    echo "⚙️  Setting up secrets..."

    if [[ ! -f "$ROOT_ENV_FILE" ]]; then
        if [[ -f .env.example ]]; then
            cp .env.example "$ROOT_ENV_FILE"
            echo "  ✅ Created data/.env from template"
        fi
    fi
    if ! grep -q "^WORKSPACE_DIR" "$ROOT_ENV_FILE" 2>/dev/null; then
        echo "WORKSPACE_DIR=./workspace" >> "$ROOT_ENV_FILE"
        echo "  ✅ Added WORKSPACE_DIR to data/.env"
    fi

    for dir in data/*/; do
        if [[ -f "$dir/.env.example" ]] && [[ ! -f "$dir/.env" ]]; then
            cp "$dir/.env.example" "$dir/.env"
            echo "  ✅ Created $dir.env from template"
        fi
    done

    if ! grep -q "^API_SERVER_KEY=" "$ROOT_ENV_FILE" 2>/dev/null; then
        API_SERVER_KEY=$(openssl rand -hex 32)
        echo "API_SERVER_KEY=$API_SERVER_KEY" >> "$ROOT_ENV_FILE"
        echo "  ✅ Generated API_SERVER_KEY"
    else
        echo "  ℹ️  API_SERVER_KEY already set"
    fi

    if ! grep -q "^WEBUI_SECRET_KEY=" data/open-webui/.env 2>/dev/null; then
        WEBUI_SECRET_KEY=$(openssl rand -hex 32)
        echo "WEBUI_SECRET_KEY=$WEBUI_SECRET_KEY" >> data/open-webui/.env
        echo "  ✅ Generated WEBUI_SECRET_KEY"
    else
        echo "  ℹ️  WEBUI_SECRET_KEY already set"
    fi

    # shellcheck source=/dev/null
    set -a && source "$ROOT_ENV_FILE" && set +a

    echo ""
    echo "🚀 Running hermes setup in container..."

    if [[ -t 0 ]]; then
        DOCKER_FLAGS="-it"
    else
        DOCKER_FLAGS="-i"
    fi

    docker run --rm $DOCKER_FLAGS \
        --user "10000:10000" \
        --network "$HERMES_NETWORK" \
        --env-file "$ROOT_ENV_FILE" \
        -v "${WORKSPACE_DIR:-./workspace}:/workspace" \
        -v "${SCRIPT_DIR}/data/hermes:/opt/data" \
        "$HERMES_IMAGE" \
        setup

    echo "⚙️  Applying performance defaults..."

    docker run --rm --user "10000:10000" --entrypoint python3 \
        -v "${SCRIPT_DIR}/data/hermes:/opt/data" \
        "$HERMES_IMAGE" \
        -c "
import yaml
with open('/opt/data/config.yaml') as f:
    config = yaml.safe_load(f)
config.setdefault('model', {})['context_length'] = 131072
config.setdefault('delegation', {})['max_iterations'] = 100
config.setdefault('goals', {})['max_turns'] = 100
# Remove compression context_length so it inherits from main model
comp = config.get('auxiliary', {}).get('compression', {})
comp.pop('context_length', None)
with open('/opt/data/config.yaml', 'w') as f:
    yaml.dump(config, f, default_flow_style=False)
print('  ✅ model.context_length set to 131072')
print('  ✅ delegation.max_iterations set to 100')
print('  ✅ goals.max_turns set to 100')
print('  ✅ compression.context_length removed (inherits from main)')
"

    echo "📂  Installing skills and hints..."

    if [[ -d "${SCRIPT_DIR}/skills" ]]; then
        docker run --rm --entrypoint bash \
            -v "${SCRIPT_DIR}/skills:/opt/skills:ro" \
            -v "${SCRIPT_DIR}/data/hermes:/opt/data" \
            "$HERMES_IMAGE" \
            -c "
        for skill in /opt/skills/*/*/; do
            category=\$(basename \"\$(dirname \"\$skill\")\")
            name=\$(basename \"\$skill\")
            mkdir -p \"/opt/data/skills/\$category\"
            cp -r \"\$skill\" \"/opt/data/skills/\$category/\$name\"
            echo \"  Installed skill: \$category/\$name\"
            if [ -f \"\$skill/hints\" ]; then
                mkdir -p /opt/data/.hermes-stack/hints
                cp \"\$skill/hints\" \"/opt/data/.hermes-stack/hints/\$name\"
                echo \"  Installed hint: \$name\"
            fi
        done
        "
    fi

    if [[ -d "${SCRIPT_DIR}/hints" ]]; then
        docker run --rm --entrypoint bash \
            -v "${SCRIPT_DIR}/hints:/opt/hints:ro" \
            -v "${SCRIPT_DIR}/data/hermes:/opt/data" \
            "$HERMES_IMAGE" \
            -c "
        mkdir -p /opt/data/.hermes-stack/hints
        for f in /opt/hints/*; do
            cp \"\$f\" \"/opt/data/.hermes-stack/hints/\$(basename \"\$f\")\"
            echo \"  Installed hint: \$(basename \"\$f\")\"
        done
        "
    fi

    if [[ -d "${SCRIPT_DIR}/bootstrap" ]]; then
        docker run --rm --entrypoint bash \
            -v "${SCRIPT_DIR}/bootstrap:/opt/bootstrap:ro" \
            -v "${SCRIPT_DIR}/data/hermes:/opt/data" \
            "$HERMES_IMAGE" \
            -c "
        mkdir -p /opt/data/.hermes-stack/bootstrap
        for f in /opt/bootstrap/*.sh; do
            cp \"\$f\" \"/opt/data/.hermes-stack/bootstrap/\"
            echo \"  Installed bootstrap: \$(basename \"\$f\")\"
        done
        "
    fi

    # Fix ownership after hermes setup
    chown -R "$(id -u):$(id -g)" "${SCRIPT_DIR}/data/hermes" 2>/dev/null || true
    ;;

status)
    echo "━━━ Container Status ━━━━━━━━━━━━━━━━━━━━━━━━━"
    $DOCKER_COMPOSE ps -a
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    ;;

# -------------------------------------------------
# Run interactive container
# -------------------------------------------------
run)
    ARGS="${2:-bash}"
    if [[ "$ARGS" == "help" ]] || [[ "$ARGS" == "-h" ]]; then
        echo "Usage: $0 run [command]"
        echo "  Spawn an interactive hermes container and run the given command."
        echo "  Default command: bash"
        echo ""
        echo "Examples:"
        echo "  $0 run              # interactive bash"
        echo "  $0 run opencode     # run opencode"
        echo "  $0 run pwd        # run pwd"
        exit 0
    fi

    echo "🚀 Spawning hermes container with: $ARGS"
    docker run --rm -it \
        --network "$HERMES_NETWORK" \
        --env-file "$ROOT_ENV_FILE" \
        -v "${WORKSPACE_DIR:-./workspace}:/workspace" \
        -v "${SCRIPT_DIR}/data/hermes:/opt/data" \
        "$HERMES_IMAGE" \
        "$ARGS"
    ;;

# -------------------------------------------------
# Install
# -------------------------------------------------
install)
    TYPE="${2:-}"
    FORCE=0
    shift || true
    shift || true  # Skip "install" and get next arg
    for arg in "$@"; do
        [[ "$arg" == "--force" ]] && FORCE=1
    done

    case "$TYPE" in
        skills)
            echo "📂 Installing skills..."
            mkdir -p data/hermes/skills
            if [[ -d "skills" ]]; then
                # Copy each subdirectory recursively (e.g., skills/mcp/ -> data/hermes/skills/mcp/)
                for skill in skills/*/*/; do
                    skill_category=$(basename "$(dirname "$skill")")
                    skill_name=$(basename "$skill")
                    dest_dir="data/hermes/skills/$skill_category/$skill_name"
                    if [[ -d "$dest_dir" ]] && [[ $FORCE -eq 0 ]]; then
                        echo "  ⏭️  Skipping existing: $skill_category/$skill_name (use --force)"
                    else
                        mkdir -p "data/hermes/skills/$skill_category"
                        rm -rf "$dest_dir"
                        cp -r "$skill" "$dest_dir"
                        echo "  ✅ Installed: $skill_category/$skill_name"
                    fi
                    # Install per-skill hints (names hint by skill name, e.g. location-query)
                    if [[ -f "$skill/hints" ]]; then
                        mkdir -p data/hermes/.hermes-stack/hints
                        cp "$skill/hints" "data/hermes/.hermes-stack/hints/$skill_name"
                        echo "  ✅ Hint installed: $skill_name"
                    fi
                    # Install per-skill bootstrap scripts
                    if [[ -f "$skill/install.sh" ]]; then
                        mkdir -p data/hermes/.hermes-stack/bootstrap
                        cp "$skill/install.sh" "data/hermes/.hermes-stack/bootstrap/$skill_name.sh"
                        echo "  ✅ Install script: $skill_name"
                    fi
                done
                # Install group-level hints for groups without individual skills (e.g., google-workspace)
                for group in skills/*/; do
                    gname=$(basename "$group")
                    if [[ -f "$group/hints" ]]; then
                        for skill_dir in "$group"*/; do
                            if [[ -f "$skill_dir/hints" ]]; then
                                continue 2
                            fi
                        done
                        mkdir -p data/hermes/.hermes-stack/hints
                        cp "$group/hints" "data/hermes/.hermes-stack/hints/$gname"
                        echo "  ✅ Hint installed: $gname"
                    fi
                done
                echo "Done installing skills."
                echo ""
                echo "ℹ️  If this skill requires configuration (e.g., MCP servers, API keys),"
                echo "   edit the relevant config files in data/hermes/"
                echo "ℹ️  Run './hermes-stack restart' to apply the new skill"
            else
                echo "No skills/ directory found in project root."
            fi
            ;;
        hints)
            echo "📂 Installing hints..."
            mkdir -p data/hermes/.hermes-stack/hints
            if [[ -d "hints" ]]; then
                for f in hints/*; do
                    hint_name=$(basename "$f")
                    if [[ -f "$f" ]]; then
                        cp "$f" "data/hermes/.hermes-stack/hints/$hint_name"
                        echo "  ✅ Installed hint: $hint_name"
                    fi
                done
                echo "Done installing hints."
            else
                echo "No hints/ directory found in project root."
            fi
            ;;
        bootstraps)
            echo "📂 Installing bootstraps..."
            mkdir -p data/hermes/.hermes-stack/bootstrap
            if [[ -d "bootstrap" ]]; then
                for f in bootstrap/*.sh; do
                    if [[ -f "$f" ]]; then
                        cp "$f" "data/hermes/.hermes-stack/bootstrap/"
                        echo "  ✅ Installed script: $(basename "$f")"
                    fi
                done
                echo "Done installing bootstraps."
            else
                echo "No bootstrap/ directory found in project root."
            fi
            ;;
        *)
            echo "Usage: $0 install {skills|hints|bootstraps} [--force]"
            echo "  skills     - Install skills from ./skills/"
            echo "  hints      - Install standalone hints from ./hints/"
            echo "  bootstraps - Install standalone scripts from ./bootstrap/"
            echo "  --force    - Overwrite existing items"
            ;;

    esac
    ;;

# -------------------------------------------------
# Backup / Restore
# -------------------------------------------------
backup)
    shift  # consume the command
    # Default retain count (override via BACKUP_RETAIN_COUNT env var)
    RETAIN_COUNT=${BACKUP_RETAIN_COUNT:-7}
    DRY_RUN=0
    # Parse optional flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --retain)
                shift
                if [[ "$1" =~ ^[0-9]+$ ]]; then
                    RETAIN_COUNT="$1"
                else
                    echo "⚠️  Invalid retain count: $1 – using default 7"
                fi
                ;;
            --dry-run)
                DRY_RUN=1
                ;;
            *)
                echo "⚠️  Unknown backup option: $1"
                ;;
        esac
        shift
done

    BACKUP_DIR="${PWD}/backup"
    mkdir -p "$BACKUP_DIR"

    TS=$(date '+%Y%m%d_%H%M%S')
    ARCHIVE="${BACKUP_DIR}/hermes-stack_${TS}.tar.gz"

    echo "📦 Creating backup → $ARCHIVE"
    tar -czf "$ARCHIVE" data workspace 2>/dev/null || true
    echo "✅ Backup created."

    # Prune old backups, keep only the newest $RETAIN_COUNT files
    TOTAL=$(find "$BACKUP_DIR" -name "hermes-stack_*.tar.gz" -maxdepth 1 2>/dev/null | wc -l)
    if [[ $TOTAL -gt $RETAIN_COUNT ]]; then
        NUM_TO_DELETE=$((TOTAL - RETAIN_COUNT))
        if [[ $DRY_RUN -eq 1 ]]; then
            echo "🧪 Dry‑run: the following $NUM_TO_DELETE backup(s) would be removed:"
            find "$BACKUP_DIR" -name "hermes-stack_*.tar.gz" -maxdepth 1 -printf "%T@ %p\n" 2>/dev/null | sort -rn | tail -n "$NUM_TO_DELETE" | cut -d" " -f2-
        else
            echo "🗑️  Pruning $NUM_TO_DELETE old backup(s) – keeping latest $RETAIN_COUNT"
            find "$BACKUP_DIR" -name "hermes-stack_*.tar.gz" -maxdepth 1 -printf "%T@ %p\n" 2>/dev/null | sort -rn | tail -n "$NUM_TO_DELETE" | cut -d" " -f2- | xargs -r rm --
            echo "✅ Prune complete: $NUM_TO_DELETE files removed, $RETAIN_COUNT newest retained."
        fi
    fi
    ;;

restore)
    read -r -p "Enter backup file (path): " f
    if [[ ! -f "$f" ]]; then
        echo "  ❌ File not found: $f"
        exit 1
    fi
    tar xzf "$f" -C .
    echo "Restored from $f"
    ;;

# -------------------------------------------------
# Docker cleanup (restored)
# -------------------------------------------------
prune)
    echo "🧹 Pruning unused Docker resources..."
    docker image prune -f
    docker volume prune -f
    echo "✅ Done"
    ;;

# -------------------------------------------------
# Env validation
# -------------------------------------------------
check-env)
    echo "Validating required environment variables..."
    MISSING=0

    # shellcheck source=/dev/null
    [[ -f "$ROOT_ENV_FILE" ]] && source "$ROOT_ENV_FILE"
    # shellcheck source=/dev/null
    [[ -f data/open-webui/.env ]] && source data/open-webui/.env

    if [[ -z "${API_SERVER_KEY:-}" ]]; then
        echo "❌ API_SERVER_KEY missing in .env"
        ((MISSING++))
    else
        echo "✅ API_SERVER_KEY set"
    fi

    if [[ -z "${WEBUI_SECRET_KEY:-}" ]]; then
        echo "❌ WEBUI_SECRET_KEY missing in data/open-webui/.env"
        ((MISSING++))
    else
        echo "✅ WEBUI_SECRET_KEY set"
    fi

    if (( MISSING )); then
        echo "Some variables are missing"
        exit 1
    else
        echo "All required variables are present."
    fi
    ;;

upgrade-base)
    echo "⬇️ Pulling latest base image..."
    docker pull "$BASE_IMAGE_NAME"

    echo "🌐 Remote digest:"
    get_remote_digest || echo "  (unable to fetch remote digest)"

    echo "💾 Local digest:"
    docker image inspect "$BASE_IMAGE_NAME" \
        --format='{{index .RepoDigests 0}}' \
        | cut -d'@' -f2
    ;;

# -------------------------------------------------
# Say - send a chat message to Hermes
# -------------------------------------------------
say)
    OUTPUT="text"
    MESSAGE=""
    for arg in "$@"; do
        case "$arg" in
            --output=json) OUTPUT="json" ;;
            --output=*) echo "Unknown output format: ${arg#*=}"; exit 1 ;;
            --*) echo "Unknown flag: $arg"; exit 1 ;;
            *) MESSAGE="$arg" ;;
        esac
    done

    if [[ -z "$MESSAGE" ]]; then
        echo "Usage: $0 say <message> [--output=json]"
        exit 1
    fi

    # shellcheck source=/dev/null
    [[ -f "$ROOT_ENV_FILE" ]] && source "$ROOT_ENV_FILE"

    if [[ -z "${API_SERVER_KEY:-}" ]]; then
        echo "❌ API_SERVER_KEY not found in .env"
        exit 1
    fi

    echo "💬 Sending: $MESSAGE"
    echo ""

    RESPONSE=$(docker exec hermes-stack-hermes-1 python3 -c "
import json, urllib.request, sys
msg = sys.argv[1]
payload = json.dumps({
    'model': 'hermes',
    'messages': [{'role': 'user', 'content': msg}],
    'stream': False
}).encode()
req = urllib.request.Request(
    'http://localhost:8642/v1/chat/completions',
    data=payload,
    headers={
        'Content-Type': 'application/json',
        'Authorization': 'Bearer $API_SERVER_KEY'
    }
)
try:
    resp = urllib.request.urlopen(req)
    print(resp.read().decode())
except Exception as e:
    print(json.dumps({'error': str(e)}))
" "$MESSAGE")

    if [[ "$OUTPUT" == "json" ]]; then
        echo "$RESPONSE" | python3 -m json.tool 2>/dev/null || echo "$RESPONSE"
    else
        echo "$RESPONSE" | python3 -c "
import json,sys
try:
    d = json.load(sys.stdin)
    if 'error' in d:
        print(f'Error: {d[\"error\"]}')
    else:
        print(d['choices'][0]['message']['content'])
except Exception as e:
    print(f'Parse error: {e}')
" 2>/dev/null || echo "Failed to parse response"
    fi
    ;;

help|--help|-h|"")
    print_help
    ;;

*)
    echo "Unknown command: $1"
    print_help
    exit 1
    ;;
esac
