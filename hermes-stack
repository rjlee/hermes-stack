#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

BASE_IMAGE_NAME="nousresearch/hermes-agent:latest"
ROOT_ENV_FILE="$(pwd)/data/.env"

# Load environment variables
# shellcheck source=/dev/null
[[ -f "$ROOT_ENV_FILE" ]] && set -a && source "$ROOT_ENV_FILE" && set +a

# Determine Hermes image
HERMES_IMAGE="${HERMES_IMAGE:-nousresearch/hermes-agent:latest}"
export HERMES_IMAGE

# Detect $DOCKER_COMPOSE variant (modern CLI vs standalone binary)
if command -v docker-compose &>/dev/null; then
    DOCKER_COMPOSE="docker-compose"
else
    DOCKER_COMPOSE="docker compose"
fi

# Compose network name (project name + network name from docker-compose.yml)
HERMES_NETWORK="${HERMES_NETWORK:-hermes-stack_hermesnet}"

print_help() {
cat <<EOF
hermes-stack – helper script for the hermes-stack project

Usage: $0 {up|down|logs|restart|backup|restore|prune|status|check-env|upgrade-base|install|help} [options]

Commands:
  up               Start the stack. Use --upgrade to pull latest images and rebuild Hermes.
  down             Stop and remove containers, networks and default volumes.
  logs             Follow live logs of all services.
  restart          Stop and start containers. Use --upgrade to pull latest and rebuild.

  model            Switch LLM model config (e.g., model free)
  backup [--retain N] [--dry-run]
                   Create a timestamped backup of data/ and workspace/.
                   The script automatically keeps only the most recent N
                   archives (default 7). Use --dry-run to list files that
                   would be pruned without deleting them.
  restore          Prompt for a backup file and extract it.
  prune            Remove unused Docker images and volumes.
  status           Show container status (health column).
  check-env        Validate required environment variables.
  upgrade-base     Pull the latest base image and display its digests.
  install skills   Install skills from ./skills/ (includes per‑skill hints and bootstraps)
  install hints    Install standalone hints from ./hints/
  install bootstraps  Install standalone bootstrap scripts from ./bootstrap/
  cli             Spawn an interactive hermes container (CLI mode)
   say <message>     Send a chat message to Hermes and print the response
                   --output=json  Print full JSON response instead of plain text
   setup [subcommand]  Set up secrets in .env and run hermes setup
                  todoist - Configure Todoist API and install todoist skills
                  life360 - Configure Life360 MCP and install location skills
                  google-workspace - Configure Google Workspace OAuth
  reset [services] Reset data directories (default: all services)
  help             Show this help message.
EOF
}

# -------------------------------------------------
# Digest helpers
# -------------------------------------------------
get_remote_digest() {
    docker manifest inspect "$BASE_IMAGE_NAME" 2>/dev/null \
        | grep -m1 '"digest"' \
        | awk -F'"' '{print $4}'
}

# -------------------------------------------------
# Google Workspace Setup
# -------------------------------------------------
setup_google_workspace()
{
    echo "📧 Google Workspace Configuration"
    echo ""
    echo "This command helps you set up Google Workspace (Gmail, Calendar, Drive, etc.)"
    echo "OAuth2 is required - you'll need to create credentials in Google Cloud Console."
    echo ""
    echo "=== Step 1: Enable required Google APIs ==="
    echo "1. Go to: https://console.cloud.google.com/apis/library"
    echo "2. Enable these APIs (search and enable each):"
    echo "   - Google Calendar API (required for calendar)"
    echo "   - Gmail API (required for email)"
    echo "   - Google Drive API (required for files)"
    echo "   - Google People API (required for contacts)"
    echo "   - Google Docs API (required for documents)"
    echo "   - Google Sheets API (required for spreadsheets)"
    echo ""
    echo "=== Step 2: Create OAuth credentials in Google Cloud Console ==="
    echo "1. Go to: https://console.cloud.google.com/apis/credentials"
    echo "2. Click 'Create Credentials' → 'OAuth client ID'"
    echo "3. Application type: Select 'Web application'"
    echo "4. Name: 'Hermes Agent' (or any name you prefer)"
    echo "5. Authorized redirect URIs: Add 'http://localhost:1'"
    echo "6. Click 'Create'"
    echo "7. Download the JSON file (click 'Download JSON')"
    echo ""
    echo "=== Step 3: Choose services and permissions ==="
    echo "Available services:"
    echo "  - gmail     : Read/send emails"
    echo "  - calendar : Calendar events"
    echo "  - drive   : Drive files"
    echo "  - contacts: Google contacts"
    echo "  - docs    : Google Docs"
    echo "  - sheets  : Google Sheets"
    echo ""
    echo "Read-only scopes are available for gmail and drive (safer option)."
    echo ""
    echo "For full setup instructions, visit:"
    echo "  https://developers.google.com/workspace/guides/create-credentials"
    echo ""
    echo "=== Step 4: Provide credentials ==="
    read -r -p "Path to client_secret.json (or press Enter to skip): " CLIENT_SECRET
    if [[ -z "$CLIENT_SECRET" ]]; then
        echo "Skipped. Run this command again with the path when ready."
        return 0
    fi
    
    if [[ ! -f "$CLIENT_SECRET" ]]; then
        echo "  ❌ File not found: $CLIENT_SECRET"
        return 1
    fi
    
    echo ""
    echo "Which services do you need? (comma-separated, or 'all'):"
    read -r -p "[all]: " SERVICES
    SERVICES="${SERVICES:-all}"
    
    echo ""
    echo "Use read-only scopes? (recommended for safety):"
    read -r -p "[y/N]: " READONLY
    READONLY="${READONLY:-n}"
    
    ENV_FILE="data/hermes/.env"
    if [[ ! -f "$ENV_FILE" ]]; then
        echo "# Hermes environment" > "$ENV_FILE"
    fi
    
    if [[ -f "$CLIENT_SECRET" ]]; then
        mkdir -p data/hermes/.google
        cp "$CLIENT_SECRET" data/hermes/.google/client_secret.json
        # Also copy to /opt/data for the google-workspace skill
        cp "$CLIENT_SECRET" data/hermes/google_client_secret.json
        echo "  ✅ Saved client credentials to data/hermes/.google/"
        # Fix permissions
        chown -R 1000:1000 data/hermes/.google data/hermes/google_client_secret.json 2>/dev/null || true
        
        grep -q "^GOOGLE_SETUP_SERVICES=" "$ENV_FILE" || printf 'GOOGLE_SETUP_SERVICES=%s\n' "$SERVICES" >> "$ENV_FILE"
        if [[ "$READONLY" == "y" ]] || [[ "$READONLY" == "Y" ]]; then
            grep -q "^GOOGLE_READONLY=" "$ENV_FILE" || echo "GOOGLE_READONLY=true" >> "$ENV_FILE"
        fi
        echo "  ✅ Configuration saved"
        echo ""
        echo "Next steps:"
        echo "  1. Run: docker exec -e PYTHONPATH=/opt/hermes hermes-stack-hermes-1 python3 \\"
        echo "       /opt/data/skills/productivity/google-workspace/scripts/setup.py --auth-url"
        echo "  2. Copy the URL from output, open in browser, authorize"
        echo "  3. In browser address bar, find 'code=XXXX' - copy just the code value"
        echo "  4. Run: docker exec -e PYTHONPATH=/opt/hermes hermes-stack-hermes-1 python3 \\"
        echo "       /opt/data/skills/productivity/google-workspace/scripts/setup.py --auth-code CODE"
        echo "     (replace CODE with the code from step 3)"
        echo "  5. Restart hermes: $DOCKER_COMPOSE restart hermes"
    else
        echo "  ❌ Invalid path"
        return 1
    fi
    
    echo ""
    read -r -p "Restart hermes now? [y/N]: " RESTART
    if [[ "$RESTART" == "y" ]] || [[ "$RESTART" == "Y" ]]; then
        echo ""
        echo "Restarting hermes..."
        $DOCKER_COMPOSE restart hermes
    fi
}

# -------------------------------------------------
# Life360 Setup
# -------------------------------------------------
setup_life360()
{
    echo "📍 Life360 CLI Configuration"
    echo ""
    echo "Choose authentication method:"
    echo "  1) Authorization token (from Life360 app)"
    echo "  2) Username + Password"
    echo ""
    read -r -p "Enter choice [1]: " CHOICE
    CHOICE="${CHOICE:-1}"
    
    ENV_FILE="data/hermes/.env"
    
    if [[ "$CHOICE" == "1" ]]; then
        echo ""
        echo "=== Option 1: Authorization Token ==="
        echo "To get your token:"
        echo "1. Download the Life360 app:"
        echo "   - iOS: https://apps.apple.com/gb/app/life360/id335102840"
        echo "   - Android: https://play.google.com/store/apps/details?id=com.life360"
        echo "2. Sign in to your Life360 account"
        echo "3. Create a 'Circle' (family group) if you haven't already"
        echo "4. In the app, go to: Account → Settings → Account Actions"
        echo "5. Look for 'Authorization Token' or 'Legacy Token'"
        echo "6. Copy this token"
        echo ""
        read -r -p "Enter Life360 authorization token: " LIFE360_TOKEN
        
        if [[ -n "$LIFE360_TOKEN" ]]; then
            if [[ ! -f "$ENV_FILE" ]]; then
                echo "# Hermes environment" > "$ENV_FILE"
            fi
            if grep -q "^LIFE360_AUTHORIZATION=" "$ENV_FILE" 2>/dev/null; then
                grep -v "^LIFE360_AUTHORIZATION=" "$ENV_FILE" > "${ENV_FILE}.tmp"
                printf 'LIFE360_AUTHORIZATION=%s\n' "$LIFE360_TOKEN" >> "${ENV_FILE}.tmp"
                mv "${ENV_FILE}.tmp" "$ENV_FILE"
            else
                printf 'LIFE360_AUTHORIZATION=%s\n' "$LIFE360_TOKEN" >> "$ENV_FILE"
            fi
            grep -q "^LIFE360_TOKEN_TYPE=" "$ENV_FILE" || echo "LIFE360_TOKEN_TYPE=Bearer" >> "$ENV_FILE"
            echo "  ✅ Saved authorization token"
        else
            echo "No token entered."
            return 1
        fi
    elif [[ "$CHOICE" == "2" ]]; then
        echo ""
        echo "=== Option 2: Username + Password ==="
        read -r -p "Username (email): " LIFE360_USERNAME
        read -r -s -p "Password: " LIFE360_PASSWORD
        echo ""
        
        if [[ -n "$LIFE360_USERNAME" ]] && [[ -n "$LIFE360_PASSWORD" ]]; then
            if [[ ! -f "$ENV_FILE" ]]; then
                echo "# Hermes environment" > "$ENV_FILE"
            fi
            grep -q "^LIFE360_USERNAME=" "$ENV_FILE" || printf 'LIFE360_USERNAME=%s\n' "$LIFE360_USERNAME" >> "$ENV_FILE"
            grep -q "^LIFE360_PASSWORD=" "$ENV_FILE" || printf 'LIFE360_PASSWORD=%s\n' "$LIFE360_PASSWORD" >> "$ENV_FILE"
            grep -q "^LIFE360_CLIENT_ID=" "$ENV_FILE" || echo "LIFE360_CLIENT_ID=life360_mobile_app" >> "$ENV_FILE"
            echo "  ✅ Saved username/password"
        fi
    else
        echo "Invalid choice: $CHOICE"
        return 1
    fi

    echo ""
    read -r -p "Restart hermes-stack now? [y/N]: " RESTART
    if [[ "$RESTART" == "y" ]] || [[ "$RESTART" == "Y" ]]; then
        echo ""
        echo "Restarting hermes container..."
        $DOCKER_COMPOSE restart hermes
    fi
}

# -------------------------------------------------
# Todoist Setup
# -------------------------------------------------
setup_todoist()
{
    echo "📝 Todoist Configuration"
    echo ""
    echo "=== Step 1: Get Todoist API Token ==="
    echo "1. Go to: https://todoist.com/app/settings/integrations"
    echo "2. Scroll to 'Developers' section"
    echo "3. Click 'Create a new app' (or use existing)"
    echo "4. Copy the 'App Client ID' and 'App Client Secret' if creating new app"
    echo "5. OR scroll to 'Personal access tokens' section"
    echo "6. Click 'Generate a new token'"
    echo "7. Copy the generated token"
