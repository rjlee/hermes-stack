    ENV_FILE="data/hermes/.env"
    
    read -r -p "Enter your Todoist API token: " TODOIST_API_TOKEN
    if [[ -n "$TODOIST_API_TOKEN" ]]; then
        if grep -q "^TODOIST_API_TOKEN=" "$ENV_FILE" 2>/dev/null; then
            grep -v "^TODOIST_API_TOKEN=" "$ENV_FILE" > "${ENV_FILE}.tmp"
            printf 'TODOIST_API_TOKEN=%s\n' "$TODOIST_API_TOKEN" >> "${ENV_FILE}.tmp"
            mv "${ENV_FILE}.tmp" "$ENV_FILE"
            echo "  ✅ Updated TODOIST_API_TOKEN"
        else
            printf 'TODOIST_API_TOKEN=%s\n' "$TODOIST_API_TOKEN" >> "$ENV_FILE"
            echo "  ✅ Saved TODOIST_API_TOKEN"
        fi
    else
        echo "No token entered. Skipped."
        return 1
    fi
    
    echo ""
    read -r -p "Restart hermes-stack now? [y/N]: " RESTART
